{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["DOM", "DOM.Iterable", "ES2023", "ScriptHost"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "noEmitOnError": true,
    "outDir": "dist",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2023",
    "types": ["node"],
    "useDefineForClassFields": false,
    "paths": {
      "velaclaw/extension-api": ["./src/extensionAPI.ts"],
      "velaclaw/plugin-sdk": ["./src/plugin-sdk/index.ts"],
      "velaclaw/plugin-sdk/*": ["./src/plugin-sdk/*.ts"],
      "@velaclaw/plugin-sdk": ["./src/plugin-sdk/index.ts"],
      "@velaclaw/plugin-sdk/*": ["./src/plugin-sdk/*.ts"],
      "velaclaw/plugin-sdk/account-id": ["./src/plugin-sdk/account-id.ts"],
      "@velaclaw/*": ["./extensions/*"]
    }
  },
  "include": ["src/**/*", "ui/**/*", "extensions/**/*", "packages/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "**/dist/**",
    "**/__tests__/**",
    "**/test-helpers/**",
    "**/test-support/**",
    "**/test-utils/**",
    "**/*.cases.ts",
    "**/*.e2e-harness.ts",
    "**/*.mock-setup.ts",
    "**/*.mocks.ts",
    "**/*.route-test-support.ts",
    "**/*.shared-test.ts",
    "**/*.suite.ts",
    "**/*.test-loader.ts",
    "**/*.test-mocks.ts",
    "**/*.test-setup.ts",
    "**/*.test-shared.ts",
    "**/*.test-support.ts",
    "**/*.test-utils.ts",
    "**/*.testkit.ts",
    "**/*live-helpers.ts",
    "**/*suite-helpers.ts",
    "**/*test-helpers.ts",
    "**/*test-loader.ts",
    "**/*test-mocks.ts",
    "**/*test-runtime-mocks.ts",
    "**/*test-support.ts",
    "**/*test-utils.ts",
    "**/vitest*.ts",
    "src/commands/channel-test-registry.ts",
    "src/commands/test-wizard-helpers.ts",
    "src/agents/live-cache-regression-*.ts",
    "src/agents/live-cache-test-support.ts",
    "src/gateway/server.auth.shared.ts",
    "src/gateway/server.e2e-*.ts",
    "src/gateway/test-with-server.ts"
  ]
}
